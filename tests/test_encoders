"""Tests for encoder implementations"""

import pytest
import numpy as np


def test_mock_encoder(mock_encoder):
    """Test mock encoder"""
    embedding = mock_encoder.encode("test")
    assert embedding.shape == (384,)
    assert embedding.dtype == np.float32


def test_encoder_consistency(mock_encoder):
    """Test encoder produces consistent embeddings"""
    emb1 = mock_encoder.encode("test")
    emb2 = mock_encoder.encode("test")
    np.testing.assert_array_almost_equal(emb1, emb2)


def test_encoder_batch(mock_encoder):
    """Test batch encoding"""
    texts = ["test1", "test2", "test3"]
    embeddings = mock_encoder.encode(texts)
    
    assert embeddings.shape == (3, 384)
    assert embeddings.dtype == np.float32
